desc:3 Channel Clipper
desc:3 Channel Clipper [Roberto Porpora]
//tags: clipper
//author: Roberto Porpora

in_pin:input 1
in_pin:input 2
in_pin:input 3

out_pin:output 1
out_pin:output 2
out_pin:output 3

@init

function clip(input)
(
    input > 1.0 ? input = 1.0;
    input < -1.0 ? input = -1.0;
    input;
);

@slider

@sample

spl0 = clip(spl0);
spl1 = clip(spl1);
spl2 = clip(spl2);
